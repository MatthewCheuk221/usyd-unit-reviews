# Turso database (required on Vercel; optional locally — falls back to file:data/reviews.db)
# Create a free database at https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Production (Vercel): use Ollama Cloud API key from https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:4b-cloud

# Number of trusted reverse-proxies in front of this server (default: 0).
# Set to 1 if behind Cloudflare, Nginx, etc., so rate-limiting uses real IPs.
# Leave at 0 (or unset) when running without a proxy — this prevents clients
# from spoofing X-Forwarded-For to bypass rate limits.
TRUSTED_PROXY_COUNT=0

# Secret used to sign anonymous session cookies for abuse controls.
# Required in production: openssl rand -hex 32
RATE_LIMIT_COOKIE_SECRET=

# Comma-separated hosts allowed to submit POST requests.
# Required for custom domains. On Vercel, *.vercel.app hosts are auto-allowed
# via VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL — you only need this if you
# use a custom domain.
# Example: ALLOWED_ORIGINS=yourdomain.com,www.yourdomain.com
ALLOWED_ORIGINS=

# Required token for moderation APIs.
# Generate a strong random value, e.g.: openssl rand -hex 32
# GET  /api/admin/reviews/reported
# POST /api/admin/reviews/hide
ADMIN_REVIEW_TOKEN=
